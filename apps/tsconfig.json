{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/mobile/*": [
        "./mobile/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "@/context/*": [
        "./context/*"
      ],
      "@/lib/*": [
        "./lib/*"
      ],
      "@/styles/*": [
        "./styles/*"
      ],
      "@/hooks/*": [
        "./hooks/*"
      ],
      "@/services/*": [
        "./services"
      ],
      "@/i18n/*": [
        "./i18n/*"
      ],
      "@/types/*": [
        "./types/*"
      ],
      "@/config/*": [
        "./config/*"
      ],
      "@/content/*": [
        "./content/*"
      ],
      "@/data/*": [
        "./data/*"
      ],
      "@/utils/*": [
        "./utils/*"
      ],
      "@/constents/*": [
        "./constents/*"
      ]
    },
    "types": [
      "next",
      "node"
    ],
    "allowImportingTsExtensions": true
  },
  "include": [
    "next-env.d.ts",
    "expo-env.d.ts",
    "mobile/expo-env.d.ts",
    ".expo/types/**/*.ts",
    "mobile/.expo/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "test/**"
  ],
  "ts-node": {
    "esm": true,
    "compilerOptions": {
      "module": "esnext"
    }
  },
  "extends": "./node_modules/expo/tsconfig.base.json"
}
