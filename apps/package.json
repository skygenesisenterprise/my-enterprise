{
  "name": "@my-enterprise/app",
  "version": "1.0.0",
  "description": "Frontend application for My Enterprise App & Mobile Experience",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "dev:mobile": "npx expo start",
    "dev:web": "DOCS_DEV=false pnpm next dev -p 3000 -H 0.0.0.0",
    "dev:docs": "DOCS_DEV=true pnpm next dev --webpack -p 3000 -H 0.0.0.0",
    "build": "next build",
    "build:web": "node ./scripts/build-web.mjs",
    "build:capacitor": "CAPACITOR=true next build",
    "web:start": "next start",
    "web:lint": "eslint",
    "dev:local": "NODE_ENV=development ./start-dev.sh",
    "dev:debug": "NODE_ENV=development DEBUG=* ./start-dev.sh",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next out",
    "electron:build": "pnpm build && pnpm --filter @aether-mail/electron build",
    "electron:start": "pnpm electron:build && electron .",
    "electron:preview": "pnpm build && electron dist-electron/main/index.mjs",
    "build:ios": "pnpm build:capacitor && npx cap sync ios && npx cap build ios",
    "build:android": "pnpm build:capacitor && npx cap sync android && npx cap build android",
    "i18n:unused": "node --experimental-strip-types scripts/find-unused-i18n.ts",
    "start": "npx expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/ui": "~56.0.17",
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@loglayer/transport-pino": "^3.2.0",
    "@next/third-parties": "16.2.9",
    "@prisma/client": "7.7.0",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-aspect-ratio": "1.1.8",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.4",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-menubar": "1.1.16",
