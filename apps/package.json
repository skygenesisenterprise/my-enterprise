{
  "name": "@my-enterprise/apps",
  "version": "1.0.0",
  "description": "Frontend application for My Enterprise App & Mobile Experience",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "dev:mobile": "pnpm exec expo start",
    "mobile:start": "pnpm exec expo start",
    "mobile:start:clear": "pnpm exec expo start -c",
    "mobile:android": "pnpm exec expo start --android",
    "mobile:ios": "pnpm exec expo start --ios",
    "mobile:web": "pnpm exec expo start --web",
    "mobile:doctor": "pnpm exec expo-doctor",
    "mobile:install": "pnpm exec expo install",
    "mobile:fix": "pnpm exec expo install --fix",
    "mobile:lint": "pnpm exec expo lint",
    "dev:web": "DOCS_DEV=false pnpm next dev -p 3000 -H 0.0.0.0",
    "dev:docs": "DOCS_DEV=true pnpm next dev --webpack -p 3000 -H 0.0.0.0",
    "build": "next build",
    "build:web": "node ./scripts/build-web.mjs",
    "build:capacitor": "CAPACITOR=true next build",
    "web:start": "next start",
    "web:lint": "eslint",
    "dev:local": "NODE_ENV=development ./start-dev.sh",
    "dev:debug": "NODE_ENV=development DEBUG=* ./start-dev.sh",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next out .expo mobile/.expo",
    "electron:build": "pnpm build && pnpm --filter @aether-mail/electron build",
    "electron:start": "pnpm electron:build && electron .",
    "electron:preview": "pnpm build && electron dist-electron/main/index.mjs",
    "build:ios": "pnpm build:capacitor && pnpm exec cap sync ios && pnpm exec cap build ios",
    "build:android": "pnpm build:capacitor && pnpm exec cap sync android && pnpm exec cap build android",
    "i18n:unused": "node --experimental-strip-types scripts/find-unused-i18n.ts",
    "start": "pnpm exec expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "pnpm exec expo start --android",
    "ios": "pnpm exec expo start --ios",
    "web": "pnpm exec expo start --web",
    "lint": "pnpm exec expo lint"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@loglayer/transport-pino": "^3.2.0",
    "@next/third-parties": "16.2.9",
    "@prisma/client": "7.7.0",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-aspect-ratio": "1.1.8",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.4",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-navigation-menu": "1.2.15",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.4.0",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.14",
    "@radix-ui/react-toast": "1.2.16",
    "@radix-ui/react-toggle": "1.1.11",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "@vercel/analytics": "^2.0.1",
    "aether-identity": "^1.0.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "embla-carousel-react": "8.6.0",
    "expo": "~54.0.2",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.12",
    "expo-glass-effect": "~0.1.10",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "framer-motion": "^12.40.0",
    "fumadocs-core": "16.2.3",
    "fumadocs-mdx": "14.1.0",
    "fumadocs-openapi": "10.1.1",
    "fumadocs-ui": "16.2.3",
    "google": "link:next/fond/google",
    "input-otp": "1.4.2",
    "loglayer": "^9.1.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.4",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-day-picker": "10.0.1",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.78.0",
    "react-markdown": "^10.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "4.16.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25",
    "@types/react": "^19.1.17",
    "@types/react-dom": "^19.1.11",
    "autoprefixer": "^10.5.0",
    "eslint": "^10",
    "eslint-config-next": "16.2.7",
    "postcss": "^8.5.15",
    "prisma": "7.6.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3"
  }
}
