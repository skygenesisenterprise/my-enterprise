# Copy this file to .env and fill in the values needed by local scripts.
# Do not commit real API keys.

# DeepL API key used by app/scripts/translate.ts.
# You can also use DEEPL_API_KEY if your environment already exposes that name.
DEEPL_AUTH_KEY=your_deepl_auth_key_here

# Optional alias supported by the translation script.
# DEEPL_API_KEY=your_deepl_auth_key_here
